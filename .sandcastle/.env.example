# Cursor API key (recommended)
# You can also pass --api-key directly to the agent CLI.
CURSOR_API_KEY=
# Model for sandcastle agent runs (default: composer-2).
# If you see resource_exhausted, try auto, composer-1, or claude-sonnet-4-6.
SANDCASTLE_CURSOR_MODEL=composer-2
# GitHub personal access token
GH_TOKEN=
