{
  "name": "@virtality/auth",
  "version": "1.0.0",
  "description": "Authentication for the Virtality platform",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/auth.ts",
      "default": "./dist/auth.js"
    }
  },
  "scripts": {
    "build": "rimraf dist && tsc",
    "dev": "tsc --watch",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@better-auth/stripe": "1.5.5",
    "@prisma/adapter-pg": "7.2.0",
    "@prisma/client": "7.2.0",
    "@virtality/db": "workspace:*",
    "@virtality/ui": "workspace:*",
    "@virtality/nodemailer": "workspace:*",
    "@virtality/shared": "workspace:*",
    "stripe": "18.5.0",
    "better-auth": "1.5.5"
  },
  "devDependencies": {
    "@virtality/typescript-config": "workspace:*",
    "tsx": "4.20.6",
    "typescript": "5.9.3"
  }
}
