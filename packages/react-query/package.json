{
  "name": "@virtality/react-query",
  "version": "0.0.1",
  "description": "TanStack Query hooks and provider for Virtality oRPC API",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./provider": {
      "types": "./src/provider.tsx",
      "default": "./dist/provider.js"
    }
  },
  "scripts": {
    "build": "rimraf dist && tsc",
    "dev": "tsc --watch",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@orpc/tanstack-query": "1.13.5",
    "@tanstack/react-query": "5.90.12",
    "@tanstack/react-query-devtools": "5.91.3",
    "@virtality/db": "workspace:*",
    "@virtality/orpc": "workspace:*",
    "react": "19.2.3",
    "superjson": "2.2.6",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/react": "19.2.14",
    "@virtality/typescript-config": "workspace:*",
    "rimraf": "6.1.2",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  }
}
