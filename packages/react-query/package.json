{
  "name": "@virtality/react-query",
  "version": "0.0.1",
  "description": "TanStack Query hooks and provider for Virtality oRPC API",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./provider": {
      "types": "./src/provider.tsx",
      "default": "./dist/provider.js"
    },
    "./legacy": {
      "types": "./src/legacy/index.ts",
      "default": "./dist/legacy/index.js"
    }
  },
  "scripts": {
    "build": "rimraf dist && tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@orpc/tanstack-query": "1.13.5",
    "@tanstack/react-query": "5.90.20",
    "@tanstack/react-query-devtools": "5.91.3",
    "@virtality/db": "workspace:*",
    "@virtality/orpc": "workspace:*",
    "@virtality/shared": "workspace:*",
    "react": "19.2.3",
    "superjson": "2.2.6",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@testing-library/react": "16.3.2",
    "@types/react": "19.2.14",
    "@virtality/typescript-config": "workspace:*",
    "jsdom": "29.1.1",
    "rimraf": "6.1.2",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  }
}
