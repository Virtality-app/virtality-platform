{
  "name": "@virtality/ui",
  "version": "0.0.0",
  "private": true,
  "description": "Shared UI Bucket and email templates for the Virtality platform",
  "type": "module",
  "exports": {
    "./lib/utils": {
      "types": "./src/lib/utils.ts",
      "default": "./dist/src/lib/utils.js"
    },
    "./lib/table-defaults": {
      "types": "./src/lib/table-defaults.ts",
      "default": "./dist/src/lib/table-defaults.js"
    },
    "./lib/use-resource-table": {
      "types": "./src/lib/use-resource-table.ts",
      "default": "./dist/src/lib/use-resource-table.js"
    },
    "./hooks/*": {
      "types": "./src/hooks/*.ts",
      "default": "./dist/src/hooks/*.js"
    },
    "./components/*": {
      "types": "./src/components/*.tsx",
      "default": "./dist/src/components/*.js"
    },
    "./template-registry": {
      "types": "./src/components/email/template-registry.ts",
      "default": "./dist/src/components/email/template-registry.js"
    },
    "./components/email/react-to-html": {
      "types": "./src/lib/react-to-html.ts",
      "default": "./dist/src/lib/react-to-html.js"
    },
    "./render-admin-authored-email": {
      "types": "./src/lib/render-admin-authored-email.tsx",
      "default": "./dist/src/lib/render-admin-authored-email.js"
    }
  },
  "scripts": {
    "build": "rimraf dist && tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-tooltip": "1.2.8",
    "react-email": "6.9.0",
    "@tailwindcss/postcss": "4.1.18",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "0.544.0",
    "radix-ui": "1.4.3",
    "react-day-picker": "10.0.1",
    "tailwind-merge": "3.3.0"
  },
  "peerDependencies": {
    "@tanstack/react-table": "8.21.3",
    "react": "19.0.0",
    "react-dom": ">=19.0.0"
  },
  "devDependencies": {
    "@tanstack/react-table": "8.21.3",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "20.19.43",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@virtality/typescript-config": "workspace:*",
    "jsdom": "29.1.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwindcss": "4.1.18",
    "tw-animate-css": "1.4.0",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  }
}
