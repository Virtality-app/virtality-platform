{
  "name": "@virtality/ui",
  "version": "0.0.0",
  "private": true,
  "description": "Shared UI Bucket and email templates for the Virtality platform",
  "type": "module",
  "exports": {
    "./lib/utils": {
      "types": "./src/lib/utils.ts",
      "default": "./dist/src/lib/utils.js"
    },
    "./components/*": {
      "types": "./src/components/*.tsx",
      "default": "./dist/src/components/*.js"
    },
    "./template-registry": {
      "types": "./src/components/email/template-registry.ts",
      "default": "./dist/src/components/email/template-registry.js"
    },
    "./components/email/react-to-html": {
      "types": "./src/lib/react-to-html.ts",
      "default": "./dist/src/lib/react-to-html.js"
    }
  },
  "scripts": {
    "build": "rimraf dist && tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slot": "1.2.4",
    "@react-email/components": "0.0.41",
    "@react-email/render": "2.0.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "date-fns": "4.1.0",
    "lucide-react": "0.544.0",
    "radix-ui": "1.4.3",
    "react-day-picker": "10.0.1",
    "tailwind-merge": "3.3.0",
    "@tailwindcss/postcss": "4.1.18"
  },
  "peerDependencies": {
    "react": "19.0.0"
  },
  "devDependencies": {
    "@types/node": "20.11.17",
    "@types/react": "19.2.14",
    "@virtality/typescript-config": "workspace:*",
    "react": "19.2.3",
    "typescript": "5.9.3",
    "vitest": "3.2.4",
    "tailwindcss": "4.1.18",
    "tw-animate-css": "1.4.0"
  }
}
