{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".next/**"],
      "env": [
        "REDIS_SECRET",
        "CONSOLE_DATABASE_URL",
        "SENTRY_AUTH_TOKEN",
        "OTEL_DEPLOYMENT_ENVIRONMENT",
        "OTEL_EXPORTER_OTLP_ENDPOINT",
        "OTEL_EXPORTER_OTLP_LOGS_ENDPOINT",
        "OTEL_LOG_LEVEL",
        "OTEL_LOGS_ENABLED"
      ]
    },
    "@virtality/website#build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**"],
      "env": [
        "ENV",
        "NEXT_PUBLIC_ENV",
        "CONSOLE_DATABASE_URL",
        "X_URL",
        "LINKEDIN_URL",
        "FACEBOOK_URL",
        "INSTAGRAM_URL",
        "OTEL_DEPLOYMENT_ENVIRONMENT",
        "OTEL_EXPORTER_OTLP_ENDPOINT",
        "OTEL_EXPORTER_OTLP_LOGS_ENDPOINT",
        "OTEL_LOG_LEVEL",
        "OTEL_LOGS_ENABLED"
      ]
    },
    "@virtality/adminboard#build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**"],
      "env": [
        "ENV",
        "NEXT_PUBLIC_ENV",
        "CONSOLE_DATABASE_URL",
        "OTEL_DEPLOYMENT_ENVIRONMENT",
        "OTEL_EXPORTER_OTLP_ENDPOINT",
        "OTEL_EXPORTER_OTLP_LOGS_ENDPOINT",
        "OTEL_LOG_LEVEL",
        "OTEL_LOGS_ENABLED"
      ]
    },
    "@virtality/console#build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**"],
      "env": [
        "REDIS_SECRET",
        "ENV",
        "OTEL_DEPLOYMENT_ENVIRONMENT",
        "OTEL_EXPORTER_OTLP_ENDPOINT",
        "OTEL_EXPORTER_OTLP_LOGS_ENDPOINT",
        "OTEL_LOG_LEVEL",
        "OTEL_LOGS_ENABLED"
      ]
    },
    "@virtality/server#build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", "console/prisma/generated/**"],
      "env": [
        "CONSOLE_DATABASE_URL",
        "SENTRY_AUTH_TOKEN",
        "NEXT_PUBLIC_ENV",
        "ENV",
        "OTEL_DEPLOYMENT_ENVIRONMENT",
        "OTEL_EXPORTER_OTLP_ENDPOINT",
        "OTEL_EXPORTER_OTLP_LOGS_ENDPOINT",
        "OTEL_LOG_LEVEL",
        "OTEL_LOGS_ENABLED"
      ]
    },
    "@virtality/socket": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "env": [
        "PORT",
        "ENV",
        "OTEL_DEPLOYMENT_ENVIRONMENT",
        "OTEL_EXPORTER_OTLP_ENDPOINT",
        "OTEL_EXPORTER_OTLP_LOGS_ENDPOINT",
        "OTEL_LOG_LEVEL",
        "OTEL_LOGS_ENABLED"
      ]
    },
    "@virtality/db#build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", "console/prisma/generated/**"],
      "env": ["CONSOLE_DATABASE_URL"]
    },
    "@virtality/auth#build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"],
      "env": ["ENV"]
    },
    "build:packages": {
      "dependsOn": ["^build"],
      "with": [
        "@virtality/shared#build",
        "@virtality/db#build",
        "@virtality/orpc#build",
        "@virtality/auth#build",
        "@virtality/ui#build",
        "@virtality/nodemailer#build"
      ],
      "outputs": ["dist/**"],
      "env": []
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "interactive": true,
      "env": [
        "OTEL_DEPLOYMENT_ENVIRONMENT",
        "OTEL_EXPORTER_OTLP_ENDPOINT",
        "OTEL_EXPORTER_OTLP_LOGS_ENDPOINT",
        "OTEL_LOG_LEVEL",
        "OTEL_LOGS_ENABLED"
      ]
    },
    "dev:apps": {
      "with": [
        "@virtality/console#dev",
        "@virtality/adminboard#dev",
        "@virtality/website#dev",
        "@virtality/server#dev"
      ],
      "cache": false,
      "persistent": true,
      "interactive": true,
      "env": [
        "OTEL_DEPLOYMENT_ENVIRONMENT",
        "OTEL_EXPORTER_OTLP_ENDPOINT",
        "OTEL_EXPORTER_OTLP_LOGS_ENDPOINT",
        "OTEL_LOG_LEVEL",
        "OTEL_LOGS_ENABLED"
      ]
    },
    "dev:console": {
      "with": [
        "@virtality/console#dev",
        "@virtality/server#dev",
        "@virtality/orpc#dev"
      ],
      "cache": false,
      "persistent": true,
      "interactive": true,
      "env": [
        "OTEL_DEPLOYMENT_ENVIRONMENT",
        "OTEL_EXPORTER_OTLP_ENDPOINT",
        "OTEL_EXPORTER_OTLP_LOGS_ENDPOINT",
        "OTEL_LOG_LEVEL",
        "OTEL_LOGS_ENABLED"
      ]
    },
    "dev:adminboard": {
      "with": ["@virtality/adminboard#dev", "@virtality/server#dev"],
      "cache": false,
      "persistent": true,
      "interactive": true,
      "env": [
        "OTEL_DEPLOYMENT_ENVIRONMENT",
        "OTEL_EXPORTER_OTLP_ENDPOINT",
        "OTEL_EXPORTER_OTLP_LOGS_ENDPOINT",
        "OTEL_LOG_LEVEL",
        "OTEL_LOGS_ENABLED"
      ]
    },
    "dev:website": {
      "with": ["@virtality/website#dev", "@virtality/server#dev"],
      "cache": false,
      "persistent": true,
      "interactive": true,
      "env": [
        "OTEL_DEPLOYMENT_ENVIRONMENT",
        "OTEL_EXPORTER_OTLP_ENDPOINT",
        "OTEL_EXPORTER_OTLP_LOGS_ENDPOINT",
        "OTEL_LOG_LEVEL",
        "OTEL_LOGS_ENABLED"
      ]
    },
    "start": {
      "cache": false,
      "persistent": true,
      "env": [
        "OTEL_DEPLOYMENT_ENVIRONMENT",
        "OTEL_EXPORTER_OTLP_ENDPOINT",
        "OTEL_EXPORTER_OTLP_LOGS_ENDPOINT",
        "OTEL_LOG_LEVEL",
        "OTEL_LOGS_ENABLED"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "type-check": {
      "dependsOn": ["^type-check"]
    },
    "@virtality/db#generate": {
      "outputs": ["console/prisma/generated/**"]
    },
    "@virtality/db#migrate:dev": {
      "outputs": ["console/prisma/generated/**"],
      "cache": false,
      "persistent": true
    },
    "@virtality/db#migrate:deploy": {
      "outputs": ["console/prisma/generated/**"],
      "cache": false,
      "persistent": true
    },
    "@virtality/db#studio": {
      "cache": false,
      "persistent": true
    }
  }
}
